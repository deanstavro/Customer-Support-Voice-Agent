# LiveKit — get these from LiveKit Cloud (or your self-hosted server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI — used for STT (Whisper), LLM, and TTS
OPENAI_API_KEY=

# Neo4j — memory graph (long-term knowledge + reasoning memory). Unused until
# the context layer lands.
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
