# LiveKit — get these from LiveKit Cloud (or your self-hosted server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI — used for STT (Whisper), LLM, and TTS
OPENAI_API_KEY=

# Neo4j — knowledge graph recall (Chunk nodes + vector index)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# --- Optional overrides (defaults in agent/config.py and agent/prompts/) ---
# AGENT_INSTRUCTIONS_FILE=agent/prompts/system.txt
# AGENT_GREETING_FILE=agent/prompts/greeting.txt
# LLM_MODEL=gpt-4o
# TTS_VOICE=alloy
# TTS_MODEL=
# STT_MODEL=
# TURN_DETECTION=livekit
# NEO4J_VECTOR_INDEX=chunk_embeddings
# RECALL_ENABLED=true
# RECALL_TOP_K=3
# RECALL_GRAPH_HOPS=4
# RECALL_MIN_WORDS=4
# RECALL_TOPIC_OVERLAP=0.25
# DOCS_URL=
